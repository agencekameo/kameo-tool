generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  DEVELOPER
  REDACTEUR
  DESIGNER
  COMMERCIAL
  DEMO
}

enum ProjectType {
  WORDPRESS
  FRAMER
  CUSTOM
  ECOMMERCE
}

enum ProjectStatus {
  BRIEF
  REDACTION
  MAQUETTE
  DEVELOPPEMENT
  INTEGRATION
  OPTIMISATIONS
  TESTING
  CONCEPTION
  REVIEW
  LIVRAISON
  MAINTENANCE
  ARCHIVE
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  REVIEW
  DONE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum MaintenancePlan {
  NONE
  HEBERGEMENT
  CLASSIQUE
  CONTENU
  SEO
}

enum ResourceCategory {
  PROCESS
  CAHIER_CHARGES
  PLUGIN
  GUIDE
  PROMPT
  SEO
  AUTRE
}

enum MaintenanceType {
  WEB
  GOOGLE
  RESEAUX
  BLOG
}

enum MaintenanceBilling {
  MENSUEL
  TRIMESTRIEL
  ANNUEL
  MANUEL
}

enum ProspectStatus {
  A_CONTACTER
  PAS_REPONDU
  A_RAPPELER
  MAIL_ENVOYE
  VISIO_PLANIFIE
  DEVIS_TRANSMETTRE
  DEVIS_ENVOYE
  A_RELANCER
  REFUSE
  SIGNE
}

enum ExpenseCategory {
  SALAIRE
  LOGICIEL
  ABONNEMENT
  ASSURANCE
  BANQUE
  FOURNISSEUR
  DOMICILIATION
  AUTRE
}

enum QuoteStatus {
  EN_ATTENTE
  BROUILLON
  ENVOYE
  ACCEPTE
  REFUSE
  EXPIRE
}

enum AbsenceType {
  MALADIE
  CONGES_PAYES
  RTT
  SANS_SOLDE
  TELETRAVAIL
  AUTRE
}

enum BackupStatus {
  OK
  PARTIAL
  FAILED
  EN_COURS
}

enum ProjectDocCategory {
  CAHIER_DES_CHARGES
  INFO_PROJET
  CHARTE_GRAPHIQUE
  CONTENU_CLIENT
  DOCUMENT_LEGAL
  AUTRE
}

enum MissionStatus {
  EN_ATTENTE
  CONTRE_PROPOSITION
  VALIDE
  REFUSE
}

enum ExpenseStatus {
  EN_ATTENTE
  VALIDE
  REMBOURSE
  REFUSE
}

model User {
  id        String    @id @default(cuid())
  name      String
  email     String    @unique
  password  String
  role      Role      @default(DEVELOPER)
  avatar    String?
  lastSeen  DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  assignedTasks           Task[]               @relation("TaskAssignee")
  createdProjects         Project[]            @relation("ProjectCreator")
  projectAssignments      ProjectAssignee[]
  audits                  Audit[]
  prospects               Prospect[]
  leadSearches            LeadSearch[]
  invoicesUploaded        ProjectInvoice[]     @relation("InvoiceUploader")
  invoicesAssigned        ProjectInvoice[]     @relation("InvoiceAssignee")
  projectDocuments        ProjectDocument[]    @relation("DocUploader")
  logs                    Log[]
  absences                Absence[]
  expenseReports          ExpenseReport[]
  quotes                  Quote[]
  messages                Message[]
  conversationMemberships ConversationMember[]
  cahiersDesCharges       CahierDesCharges[]
  redactions              Redaction[]            @relation("RedactionCreator")
  skillProgress           SkillProgress[]
  notifications           Notification[]
  relances                Relance[]              @relation("Relances")
  speeches                CommercialSpeech[]     @relation("Speeches")
  commissions             CommercialCommission[] @relation("Commissions")
  createdClients          Client[]               @relation("ClientCreator")
  createdResources        Resource[]             @relation("ResourceCreator")
  createdMaintenances     MaintenanceContract[]  @relation("MaintenanceCreator")
  createdContracts        Contract[]             @relation("ContractCreator")
  createdMandats          Mandat[]               @relation("MandatCreator")
  createdExpenses         Expense[]              @relation("ExpenseCreator")
  createdArticleTemplates ArticleTemplate[]      @relation("ArticleTemplateCreator")
  smallProjectsFreelance  SmallProject[]         @relation("SmallProjectFreelance")
  gmbProjects             GmbProject[]           @relation("gmbProjects")
}

model Log {
  id          String   @id @default(cuid())
  userId      String
  action      String
  entity      String
  entityId    String?
  entityLabel String?
  details     String?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  message   String
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([userId, createdAt])
}

model Client {
  id               String          @id @default(cuid())
  name             String
  firstName        String?
  lastName         String?
  email            String?
  phone            String?
  company          String?
  siret            String?
  website          String?
  logo             String?
  address          String?
  postalCode       String?
  city             String?
  country          String?         @default("France")
  notes            String?
  contact2Name     String?
  contact2Email    String?
  contact2Phone    String?
  maintenancePlan  MaintenancePlan @default(NONE)
  maintenancePrice Float?
  createdById      String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  createdBy      User?          @relation("ClientCreator", fields: [createdById], references: [id])
  projects       Project[]
  quotes         Quote[]
  backups        SiteBackup[]
  smallProjects  SmallProject[]
}

model Project {
  id          String        @id @default(cuid())
  name        String
  clientId    String
  type        ProjectType
  status      ProjectStatus @default(BRIEF)
  price       Float?
  services    String[]
  deadline    DateTime?
  startDate   DateTime?
  notes           String?
  clientBrief     String?   @db.Text
  figmaUrl        String?
  contentUrl      String?
  reviewReceived  Boolean       @default(false)
  reviewExcluded  Boolean       @default(false)
  formBypassedAt  DateTime?
  maintenancePlan  MaintenancePlan @default(NONE)
  maintenancePrice Float?
  signedAt          DateTime?
  maintenanceStart DateTime?
  maintenanceEnd   DateTime?
  createdById String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  client       Client           @relation(fields: [clientId], references: [id], onDelete: Cascade)
  createdBy    User             @relation("ProjectCreator", fields: [createdById], references: [id])
  tasks        Task[]
  audits       Audit[]
  assignments  ProjectAssignee[]
  invoices     ProjectInvoice[]
  documents    ProjectDocument[]
  conversation       Conversation?
  cahiersDesCharges  CahierDesCharges[]
  clientForm         ClientForm?
  redactions         Redaction[]
  partners           Partner[]

  @@index([clientId])
  @@index([status])
  @@index([updatedAt])
}

model ProjectAssignee {
  id              String        @id @default(cuid())
  projectId       String
  userId          String
  price           Float?
  delayDays       Int?
  deadline        DateTime?
  status          MissionStatus @default(EN_ATTENTE)
  counterPrice    Float?
  counterDeadline DateTime?
  counterNote     String?
  respondedAt     DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([userId])
  @@index([projectId])
}

model Task {
  id             String       @id @default(cuid())
  title          String
  description    String?
  status         TaskStatus   @default(TODO)
  priority       TaskPriority @default(MEDIUM)
  projectId      String?
  assigneeId     String?
  dueDate        DateTime?
  recurring      Boolean      @default(false)
  recurrenceType String?
  position       Int          @default(0)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  project  Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignee User?    @relation("TaskAssignee", fields: [assigneeId], references: [id])

  @@index([projectId])
  @@index([assigneeId])
  @@index([status])
}

model Resource {
  id          String           @id @default(cuid())
  title       String
  content     String
  category    ResourceCategory
  tags        String[]
  pinned      Boolean          @default(false)
  createdById String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  createdBy User? @relation("ResourceCreator", fields: [createdById], references: [id])
}

model Audit {
  id                 String   @id @default(cuid())
  url                String
  projectId          String?
  createdById        String
  performanceMobile  Float?
  performanceDesktop Float?
  seoScore           Float?
  uxScore            Float?
  responsiveScore    Float?
  globalScore        Float?
  technology         String?
  traffic            String?
  keywords           String?
  details            Json?
  improvements       Json?
  createdAt          DateTime @default(now())

  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  createdBy User     @relation(fields: [createdById], references: [id])
}

model MaintenanceContract {
  id            String             @id @default(cuid())
  clientName    String
  clientEmail   String?
  url           String?
  loginUrl      String?
  cms           String?
  type          MaintenanceType    @default(WEB)
  billing       MaintenanceBilling @default(MENSUEL)
  billingDay    Int?               // Jour du prélèvement (1-31)
  startDate     DateTime?
  endDate       DateTime?
  priceHT       Float?
  commercial    String?
  loginEmail    String?
  loginPassword String?
  contactName   String?
  contactPhone  String?
  notes         String?
  active        Boolean            @default(true)
  manualPaid    Boolean            @default(false)
  level         Int?               // 1-4 for WEB maintenance level
  contractId    String?
  mandatId      String?
  createdById   String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  contract  Contract?            @relation("MaintenanceToContract", fields: [contractId], references: [id])
  mandat    Mandat?              @relation("MaintenanceToMandat", fields: [mandatId], references: [id])
  createdBy User?                @relation("MaintenanceCreator", fields: [createdById], references: [id])
  invoices  MaintenanceInvoice[]

  @@index([contractId])
  @@index([mandatId])
}

model MaintenanceInvoice {
  id              String   @id @default(cuid())
  maintenanceId   String
  number          String   @unique
  month           Int      // 1-12
  year            Int
  amountHT        Float
  amountTTC       Float
  clientName      String
  clientEmail     String?
  sentAt          DateTime?
  createdAt       DateTime @default(now())

  maintenance MaintenanceContract @relation(fields: [maintenanceId], references: [id], onDelete: Cascade)

  @@unique([maintenanceId, month, year])
  @@index([maintenanceId])
}

model Contract {
  id           String   @id @default(cuid())
  clientName   String
  clientEmail  String?
  subject      String?
  type         String   @default("PRESTATION")
  billing      String   @default("ONE_SHOT")
  priceHT      Float?
  startDate    DateTime?
  endDate      DateTime?
  contactName  String?
  contactPhone String?
  contactEmail String?
  notes        String?  @db.Text
  active       Boolean  @default(true)
  // Client document fields
  clientId         String?
  clientAddress    String?
  clientPostalCode String?
  clientCity       String?
  clientCountry    String?
  clientPhone      String?
  clientSiren      String?
  duration         String?  // ex: "12 mois", "1 an"
  maintenanceLevel Int?     // 1-4 for MAINTENANCE_WEB
  // Signature
  signatureToken  String?   @unique
  signatureStatus String    @default("BROUILLON") // BROUILLON, ENVOYE, SIGNE
  signedAt        DateTime?
  signatureData   String?   @db.Text
  signedCity      String?
  signerName      String?
  sentForSignAt   DateTime?
  stoppedAt       DateTime?  // Client a voulu arrêter (pas de reconduction tacite)
  createdById  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  createdBy     User?                @relation("ContractCreator", fields: [createdById], references: [id])
  maintenances  MaintenanceContract[] @relation("MaintenanceToContract")
  mandats       Mandat[]              @relation("MandatToContract")
}

model Mandat {
  id           String   @id @default(cuid())
  clientName   String
  clientEmail  String?
  subject      String?
  priceHT      Float?
  billing      String   @default("MENSUEL")
  startDate    DateTime?
  endDate      DateTime?
  contactName  String?
  contactPhone String?
  contactEmail String?
  notes        String?  @db.Text
  active       Boolean  @default(true)
  // Client document fields
  clientId         String?
  clientAddress    String?
  clientPostalCode String?
  clientCity       String?
  clientCountry    String?
  clientPhone2     String?
  clientSiren      String?
  clientPrenom     String?
  bic              String?
  iban             String?
  paymentType      String?  @default("RECURRENT") // RECURRENT, PONCTUEL
  referenceMandat    String?   @unique
  referenceContrat   String?
  descriptionContrat String?
  // Signature
  signatureToken  String?   @unique
  signatureStatus String    @default("BROUILLON") // BROUILLON, ENVOYE, SIGNE
  signedAt        DateTime?
  signatureData   String?   @db.Text
  signedCity      String?
  signerName      String?
  sentForSignAt   DateTime?
  stoppedAt       DateTime?  // Client a voulu arrêter
  contractId   String?
  createdById  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  contract     Contract?            @relation("MandatToContract", fields: [contractId], references: [id])
  createdBy    User?                @relation("MandatCreator", fields: [createdById], references: [id])
  maintenances MaintenanceContract[] @relation("MaintenanceToMandat")

  @@index([contractId])
}

model Review {
  id          String   @id @default(cuid())
  clientName  String   @unique
  status      String   @default("A_DEMANDER") // RECU, EN_ATTENTE, A_DEMANDER, HORS_CATEGORIE
  hidden      Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Prospect {
  id         String         @id @default(cuid())
  name       String
  firstName  String?
  lastName   String?
  company    String?
  email      String?
  phone      String?
  address    String?
  postalCode String?
  city       String?
  website    String?
  googleUrl  String?
  notes      String?
  status       ProspectStatus @default(A_CONTACTER)
  callbackDate DateTime?
  budget     Float?
  source     String?
  assignedTo String?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  cdcData        Json?
  statusHistory  String[]   @default([])
  leadSearchId   String?

  assignee    User?                  @relation(fields: [assignedTo], references: [id])
  leadSearch  LeadSearch?            @relation(fields: [leadSearchId], references: [id], onDelete: Cascade)
  relances    Relance[]
  commissions CommercialCommission[]

  @@index([assignedTo])
  @@index([status])
  @@index([leadSearchId])
}

model LeadSearch {
  id              String   @id @default(cuid())
  keyword         String
  location        String
  userId          String
  resultCount     Int      @default(0)
  withEmail       Int      @default(0)
  totalToScrape   Int      @default(0)
  scrapedCount    Int      @default(0)
  scrapingStatus  String   @default("DONE")
  createdAt       DateTime @default(now())

  user      User       @relation(fields: [userId], references: [id])
  prospects Prospect[]

  @@index([userId])
}

model Expense {
  id           String          @id @default(cuid())
  name         String
  amount       Float
  category     String          @default("AUTRE")
  recurring    Boolean         @default(true)
  notes        String?
  expenseMonth Int?
  expenseYear  Int?
  createdById  String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  createdBy User? @relation("ExpenseCreator", fields: [createdById], references: [id])
}

enum SmallProjectStatus {
  NON_COMMENCE
  EN_COURS
  TERMINE
}

model SmallProject {
  id           String             @id @default(cuid())
  name         String
  clientId     String
  price        Float
  charges      Float              @default(0)
  description  String?            @db.Text
  signedAt     DateTime
  status       SmallProjectStatus @default(NON_COMMENCE)
  freelanceId  String?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  client    Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  freelance User?  @relation("SmallProjectFreelance", fields: [freelanceId], references: [id])
}

model ProjectInvoice {
  id          String   @id @default(cuid())
  projectId   String
  uploadedBy  String
  assigneeId  String?
  filename    String
  fileUrl     String
  amount      Float?
  notes       String?
  createdAt   DateTime @default(now())

  project  Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  uploader User    @relation("InvoiceUploader", fields: [uploadedBy], references: [id])
  assignee User?   @relation("InvoiceAssignee", fields: [assigneeId], references: [id])
}

model ProjectDocument {
  id           String             @id @default(cuid())
  projectId    String
  name         String
  url          String
  category     ProjectDocCategory
  uploadedById String
  createdAt    DateTime           @default(now())

  project    Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  uploadedBy User    @relation("DocUploader", fields: [uploadedById], references: [id])
}

model ArticleTemplate {
  id          String   @id @default(cuid())
  name        String
  description String?
  unitPrice   Float
  unit        String   @default("forfait")
  deliveryDays Int?
  sortOrder   Int      @default(0)
  category    String?
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy User? @relation("ArticleTemplateCreator", fields: [createdById], references: [id])
}

model Quote {
  id            String      @id @default(cuid())
  number        String      @unique
  clientId      String?
  clientName    String
  clientEmail   String?
  clientAddress String?
  clientLogo    String?
  subject       String
  status        QuoteStatus @default(EN_ATTENTE)
  validUntil    DateTime?
  notes         String?
  discount      Float       @default(0)
  discountType  String      @default("PERCENT")
  deliveryDays  Int?
  createdById   String
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  items              QuoteItem[]
  signatureRequests  SignatureRequest[]
  client             Client?     @relation(fields: [clientId], references: [id])
  createdBy          User        @relation(fields: [createdById], references: [id])

  @@index([clientId])
  @@index([status])
  @@index([createdById])
  @@index([createdAt])
}

model QuoteItem {
  id          String @id @default(cuid())
  quoteId     String
  description String
  unit        String @default("forfait")
  quantity    Float  @default(1)
  unitPrice   Float
  tva         Float  @default(20)
  position    Int    @default(0)

  quote Quote @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@index([quoteId])
  @@index([quoteId, position])
}

model Absence {
  id        String      @id @default(cuid())
  userId    String
  date      DateTime
  endDate   DateTime?
  type      AbsenceType @default(AUTRE)
  duration  Float       @default(1)
  notes     String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SiteBackup {
  id         String       @id @default(cuid())
  clientName String
  clientId   String?
  url        String?
  provider   String?
  type       String       @default("FULL")
  size       String?
  status     BackupStatus @default(OK)
  backupDate DateTime
  notes      String?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  client Client? @relation(fields: [clientId], references: [id])
}

model ExpenseReport {
  id          String        @id @default(cuid())
  userId      String
  date        DateTime
  amount      Float
  description String
  category    String        @default("AUTRE")
  receiptUrl  String?
  status      ExpenseStatus @default(EN_ATTENTE)
  notes       String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Conversation {
  id        String   @id @default(cuid())
  name      String?
  projectId String?  @unique
  isGroup   Boolean  @default(false)
  createdAt DateTime @default(now())

  messages     Message[]
  participants ConversationMember[]
  project      Project?             @relation(fields: [projectId], references: [id], onDelete: SetNull)
}

model ConversationMember {
  id             String    @id @default(cuid())
  conversationId String
  userId         String
  joinedAt       DateTime  @default(now())
  lastReadAt     DateTime?
  archivedAt     DateTime?

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
  @@index([conversationId, archivedAt])
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  senderId       String
  content        String?
  fileUrl        String?  @db.Text
  fileType       String?
  fileName       String?
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id])

  @@index([conversationId])
  @@index([createdAt])
}

model CahierDesCharges {
  id          String   @id @default(cuid())
  title       String
  projectId   String?
  content     String   @db.Text
  prompt      String?  @db.Text
  template    String   @default("standard")
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  createdBy User     @relation(fields: [createdById], references: [id])
}

model Redaction {
  id          String   @id @default(cuid())
  projectId   String
  analysis    String   @db.Text
  content     String?  @db.Text
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy User    @relation("RedactionCreator", fields: [createdById], references: [id])
}

model GoogleCalendarToken {
  id           String   @id @default(cuid())
  email        String   @unique
  userId       String?
  accessToken  String   @db.Text
  refreshToken String   @db.Text
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model SignatureRequest {
  id              String    @id @default(cuid())
  quoteId         String
  token           String    @unique
  signerFirstName String
  signerLastName  String
  signerEmail     String
  signerPhone     String?
  signedAt        DateTime?
  signatureData   String?   @db.Text
  signedCity      String?
  signedDate      String?
  signerIp        String?
  sentAt          DateTime  @default(now())
  expiresAt       DateTime
  usedAt          DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  quote Quote @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([quoteId])
}

model ClientForm {
  id          String   @id @default(cuid())
  projectId   String   @unique
  token       String   @unique @default(cuid())
  slug        String?  @unique
  cdcData     Json?
  docsData    Json?
  briefData   Json?
  designData  Json?
  accesData   Json?
  cdcCompleted  Boolean @default(false)
  docsCompleted Boolean @default(false)
  briefCompleted Boolean @default(false)
  designCompleted Boolean @default(false)
  accesCompleted Boolean @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([token])
}

model AyshaTask {
  id             String       @id @default(cuid())
  title          String
  status         TaskStatus   @default(TODO)
  priority       TaskPriority @default(MEDIUM)
  dueDate        DateTime?
  recurring      Boolean      @default(false)
  recurrenceType String?
  position       Int          @default(0)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  subtasks AyshaSubTask[]
}

model AyshaSubTask {
  id        String   @id @default(cuid())
  taskId    String
  title     String
  done      Boolean  @default(false)
  position  Int      @default(0)
  createdAt DateTime @default(now())

  task AyshaTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   @db.Text
  updatedAt DateTime @updatedAt
}

model Relance {
  id         String   @id @default(cuid())
  prospectId String
  userId     String
  type       String   @default("APPEL")
  date       DateTime
  notes      String?
  done       Boolean  @default(false)
  createdAt  DateTime @default(now())

  prospect Prospect @relation(fields: [prospectId], references: [id], onDelete: Cascade)
  user     User     @relation("Relances", fields: [userId], references: [id])

  @@index([userId])
  @@index([prospectId])
}

model CommercialVideo {
  id          String   @id @default(cuid())
  title       String
  url         String
  description String?
  category    String?
  createdAt   DateTime @default(now())
}

model CommercialSpeech {
  id        String   @id @default(cuid())
  userId    String
  title     String
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation("Speeches", fields: [userId], references: [id])

  @@index([userId])
}

model CommercialCommission {
  id         String    @id @default(cuid())
  userId     String
  prospectId String?
  amount     Float
  type       String    @default("SIGNATURE")
  date       DateTime
  notes      String?
  paid       Boolean   @default(false)
  createdAt  DateTime  @default(now())

  user     User      @relation("Commissions", fields: [userId], references: [id])
  prospect Prospect? @relation(fields: [prospectId], references: [id])

  @@index([userId])
}

model SkillProgress {
  id        String   @id @default(cuid())
  userId    String
  itemKey   String
  completed Boolean  @default(false)
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, itemKey])
  @@index([userId])
}

// ─── Partenaires ─────────────────────────────────────────────────────────────

enum PartnerStatus {
  NOUVEAU
  MAIL_ENVOYE
  RELANCE_1
  RELANCE_2
  RDV_PRIS
  SIGNE
  REFUSE
}

model PartnerSearch {
  id             String   @id @default(cuid())
  keyword        String
  location       String
  resultCount    Int      @default(0)
  scrapingStatus String   @default("DONE") // SEARCHING, SCRAPING, DONE
  scrapedCount   Int      @default(0)
  totalToScrape  Int      @default(0)
  createdAt      DateTime @default(now())

  partners Partner[]
}

model Partner {
  id          String        @id @default(cuid())
  name        String
  category    String?
  phone       String?
  email       String?
  website     String?
  address     String?
  rating      Float?
  reviewCount Int?
  status      PartnerStatus @default(NOUVEAU)
  notes       String?

  // Mail tracking
  mailSentAt    DateTime?
  relance1At    DateTime?
  relance2At    DateTime?
  mailOpenCount Int       @default(0)
  lastOpenedAt  DateTime?
  trackingId    String?   @unique

  // Commission tracking
  projectId        String?
  commissionRate   Float     @default(20)
  commissionAmount Float?
  commissionPaid   Boolean   @default(false)
  commissionPaidAt DateTime?

  searchId  String?
  search    PartnerSearch? @relation(fields: [searchId], references: [id], onDelete: SetNull)
  project   Project?       @relation(fields: [projectId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([searchId])
  @@index([status])
}

model EmailQuota {
  id          String   @id @default(cuid())
  date        DateTime @db.Date
  account     String   // gmail account identifier
  sentCount   Int      @default(0)
  bounceCount Int      @default(0)
  failCount   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([date, account])
  @@index([date])
}

// ── Google My Business ──────────────────────────────────────────────────────

model GmbProject {
  id              String   @id @default(cuid())
  locationId      String   // Google location ID (e.g. "locations/123")
  locationName    String   // Display name
  accountId       String   // Google account ID

  // Project info
  businessName    String?
  sector          String?  // Sector / industry
  zone            String?  // Geographic zone
  keywords        String[] @default([]) // Target keywords
  targetAudience  String?  // Target audience description
  tone            String?  @default("professionnel") // Content tone
  directives      String?  // Custom directives for AI
  services        String?  // Services description
  uniquePoints    String?  // Unique selling points

  // Post settings
  postsPerMonth   Int      @default(4)
  postDays        String[] @default(["MONDAY", "THURSDAY"]) // Days to post
  postTime        String   @default("10:00") // Time to post

  // Recap settings
  recapEnabled    Boolean  @default(false)
  recapFrequency  String   @default("MENSUEL") // HEBDO, MENSUEL
  recapEmail      String?  // Client email for recaps
  recapDay        Int      @default(1) // Day of month (or day of week for HEBDO)

  createdById     String?
  createdBy       User?    @relation("gmbProjects", fields: [createdById], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  scheduledPosts  GmbScheduledPost[]
  scheduledPhotos GmbScheduledPhoto[]
  clientPortal    GmbClientPortal?

  @@unique([locationId])
  @@index([createdById])
}

model GmbScheduledPost {
  id            String   @id @default(cuid())
  projectId     String
  project       GmbProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  content       String   // Post text content
  topicType     String   @default("STANDARD") // STANDARD, OFFER, EVENT
  scheduledAt   DateTime // When to publish
  status        String   @default("BROUILLON") // BROUILLON, PLANIFIE, PUBLIE, ERREUR
  publishedAt   DateTime?
  errorMessage  String?
  aiGenerated   Boolean  @default(false)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([projectId])
  @@index([status, scheduledAt])
}

model GmbScheduledPhoto {
  id            String   @id @default(cuid())
  projectId     String
  project       GmbProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  imageUrl      String   // Vercel Blob URL
  caption       String?
  category      String   @default("ADDITIONAL") // COVER, PROFILE, ADDITIONAL, EXTERIOR, INTERIOR, PRODUCT, TEAM
  scheduledAt   DateTime // When to publish
  status        String   @default("PLANIFIE") // PLANIFIE, PUBLIE, ERREUR
  publishedAt   DateTime?
  errorMessage  String?
  fromPortal    Boolean  @default(false) // Uploaded by client via portal

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([projectId])
  @@index([status, scheduledAt])
}

model GmbClientPortal {
  id            String   @id @default(cuid())
  projectId     String   @unique
  project       GmbProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  token         String   @unique @default(cuid())
  active        Boolean  @default(true)
  clientName    String?
  clientEmail   String?
  maxPhotos     Int      @default(20) // Max photos client can upload
  instructions  String?  // Instructions for the client

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
