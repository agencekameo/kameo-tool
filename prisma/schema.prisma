generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  DEVELOPER
  REDACTEUR
  DESIGNER
  MEMBER
}

enum ProjectType {
  WORDPRESS
  FRAMER
  CUSTOM
  ECOMMERCE
}

enum ProjectStatus {
  BRIEF
  REDACTION
  MAQUETTE
  DEVELOPPEMENT
  REVIEW
  LIVRAISON
  MAINTENANCE
  ARCHIVE
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  REVIEW
  DONE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum MaintenancePlan {
  NONE
  ESSENTIELLE
  DEVELOPPEMENT
  SEO
}

enum ResourceCategory {
  PROCESS
  CAHIER_CHARGES
  PLUGIN
  GUIDE
  PROMPT
  SEO
  AUTRE
}

enum MaintenanceType {
  WEB
  GOOGLE
  RESEAUX
  BLOG
}

enum MaintenanceBilling {
  MENSUEL
  TRIMESTRIEL
  ANNUEL
}

enum ProspectStatus {
  A_CONTACTER
  DEVIS_TRANSMETTRE
  DEVIS_ENVOYE
  REFUSE
  SIGNE
}

enum ExpenseCategory {
  SALAIRE
  LOGICIEL
  ABONNEMENT
  ASSURANCE
  BANQUE
  FOURNISSEUR
  AUTRE
}

enum QuoteStatus {
  BROUILLON
  ENVOYE
  ACCEPTE
  REFUSE
  EXPIRE
}

enum AbsenceType {
  MALADIE
  CONGES_PAYES
  RTT
  SANS_SOLDE
  TELETRAVAIL
  AUTRE
}

enum BackupStatus {
  OK
  PARTIAL
  FAILED
  EN_COURS
}

enum ExpenseStatus {
  EN_ATTENTE
  VALIDE
  REMBOURSE
  REFUSE
}

model User {
  id        String    @id @default(cuid())
  name      String
  email     String    @unique
  password  String
  role      Role      @default(DEVELOPER)
  avatar    String?
  lastSeen  DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  assignedTasks           Task[]               @relation("TaskAssignee")
  createdProjects         Project[]            @relation("ProjectCreator")
  assignedProjects        Project[]            @relation("ProjectAssignees")
  audits                  Audit[]
  prospects               Prospect[]
  invoicesUploaded        ProjectInvoice[]     @relation("InvoiceUploader")
  logs                    Log[]
  absences                Absence[]
  expenseReports          ExpenseReport[]
  quotes                  Quote[]
  messages                Message[]
  conversationMemberships ConversationMember[]
}

model Log {
  id          String   @id @default(cuid())
  userId      String
  action      String
  entity      String
  entityId    String?
  entityLabel String?
  details     String?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Client {
  id               String          @id @default(cuid())
  name             String
  email            String?
  phone            String?
  company          String?
  website          String?
  address          String?
  notes            String?
  maintenancePlan  MaintenancePlan @default(NONE)
  maintenancePrice Float?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  projects Project[]
  quotes   Quote[]
  backups  SiteBackup[]
}

model Project {
  id          String        @id @default(cuid())
  name        String
  clientId    String
  type        ProjectType
  status      ProjectStatus @default(BRIEF)
  price       Float?
  services    String[]
  deadline    DateTime?
  startDate   DateTime?
  notes           String?
  reviewReceived  Boolean       @default(false)
  createdById String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  client       Client           @relation(fields: [clientId], references: [id], onDelete: Cascade)
  createdBy    User             @relation("ProjectCreator", fields: [createdById], references: [id])
  tasks        Task[]
  audits       Audit[]
  assignees    User[]           @relation("ProjectAssignees")
  invoices     ProjectInvoice[]
  conversation Conversation?
}

model Task {
  id             String       @id @default(cuid())
  title          String
  description    String?
  status         TaskStatus   @default(TODO)
  priority       TaskPriority @default(MEDIUM)
  projectId      String
  assigneeId     String?
  dueDate        DateTime?
  recurring      Boolean      @default(false)
  recurrenceType String?
  position       Int          @default(0)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  project  Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignee User?   @relation("TaskAssignee", fields: [assigneeId], references: [id])
}

model Resource {
  id        String           @id @default(cuid())
  title     String
  content   String
  category  ResourceCategory
  tags      String[]
  pinned    Boolean          @default(false)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
}

model Audit {
  id                 String   @id @default(cuid())
  url                String
  projectId          String?
  createdById        String
  performanceMobile  Float?
  performanceDesktop Float?
  seoScore           Float?
  uxScore            Float?
  responsiveScore    Float?
  globalScore        Float?
  technology         String?
  traffic            String?
  keywords           String?
  details            Json?
  improvements       Json?
  createdAt          DateTime @default(now())

  project   Project? @relation(fields: [projectId], references: [id])
  createdBy User     @relation(fields: [createdById], references: [id])
}

model MaintenanceContract {
  id            String             @id @default(cuid())
  clientName    String
  url           String?
  loginUrl      String?
  cms           String?
  type          MaintenanceType    @default(WEB)
  billing       MaintenanceBilling @default(MENSUEL)
  startDate     DateTime?
  endDate       DateTime?
  priceHT       Float?
  commercial    String?
  loginEmail    String?
  loginPassword String?
  contactName   String?
  contactPhone  String?
  notes         String?
  active        Boolean            @default(true)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
}

model Prospect {
  id         String         @id @default(cuid())
  name       String
  company    String?
  email      String?
  phone      String?
  notes      String?
  status     ProspectStatus @default(A_CONTACTER)
  budget     Float?
  source     String?
  assignedTo String?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  assignee User? @relation(fields: [assignedTo], references: [id])
}

model Expense {
  id        String          @id @default(cuid())
  name      String
  amount    Float
  category  ExpenseCategory @default(AUTRE)
  recurring Boolean         @default(true)
  notes     String?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
}

model ProjectInvoice {
  id          String   @id @default(cuid())
  projectId   String
  uploadedBy  String
  filename    String
  fileUrl     String
  amount      Float?
  notes       String?
  createdAt   DateTime @default(now())

  project  Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  uploader User    @relation("InvoiceUploader", fields: [uploadedBy], references: [id])
}

model ArticleTemplate {
  id          String   @id @default(cuid())
  name        String
  description String?
  unitPrice   Float
  unit        String   @default("forfait")
  category    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Quote {
  id            String      @id @default(cuid())
  number        String      @unique
  clientId      String?
  clientName    String
  clientEmail   String?
  clientAddress String?
  subject       String
  status        QuoteStatus @default(BROUILLON)
  validUntil    DateTime?
  notes         String?
  discount      Float       @default(0)
  createdById   String
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  items     QuoteItem[]
  client    Client?     @relation(fields: [clientId], references: [id])
  createdBy User        @relation(fields: [createdById], references: [id])
}

model QuoteItem {
  id          String @id @default(cuid())
  quoteId     String
  description String
  unit        String @default("forfait")
  quantity    Float  @default(1)
  unitPrice   Float
  tva         Float  @default(20)
  position    Int    @default(0)

  quote Quote @relation(fields: [quoteId], references: [id], onDelete: Cascade)
}

model Absence {
  id        String      @id @default(cuid())
  userId    String
  date      DateTime
  endDate   DateTime?
  type      AbsenceType @default(AUTRE)
  duration  Float       @default(1)
  notes     String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SiteBackup {
  id         String       @id @default(cuid())
  clientName String
  clientId   String?
  url        String?
  provider   String?
  type       String       @default("FULL")
  size       String?
  status     BackupStatus @default(OK)
  backupDate DateTime
  notes      String?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  client Client? @relation(fields: [clientId], references: [id])
}

model ExpenseReport {
  id          String        @id @default(cuid())
  userId      String
  date        DateTime
  amount      Float
  description String
  category    String        @default("AUTRE")
  receiptUrl  String?
  status      ExpenseStatus @default(EN_ATTENTE)
  notes       String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Conversation {
  id        String   @id @default(cuid())
  name      String?
  projectId String?  @unique
  isGroup   Boolean  @default(false)
  createdAt DateTime @default(now())

  messages     Message[]
  participants ConversationMember[]
  project      Project?             @relation(fields: [projectId], references: [id])
}

model ConversationMember {
  id             String    @id @default(cuid())
  conversationId String
  userId         String
  joinedAt       DateTime  @default(now())
  lastReadAt     DateTime?

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  senderId       String
  content        String?
  fileUrl        String?
  fileType       String?
  fileName       String?
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id])
}
